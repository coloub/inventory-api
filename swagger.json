{
  "swagger": "2.0",
  "info": {
    "version": "1.0.0",
    "title": "Inventory API"
  },
  "basePath": "/",
  "securityDefinitions": {
    "bearerAuth": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header",
      "description": "Enter your bearer token in the format **Bearer <token>**"
    }
  },
  "paths": {
    "/api/products": {
      "get": {
        "summary": "Get all products",
        "responses": {
          "200": {
            "description": "Success",
            "schema": {
              "type": "array",
              "items": { "$ref": "#/definitions/Product" }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "summary": "Create new product",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "body",
            "name": "product",
            "required": true,
            "schema": { "$ref": "#/definitions/ProductInput" }
          }
        ],
        "responses": {
          "200": {
            "description": "Created",
            "schema": { "$ref": "#/definitions/Product" }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/products/{id}": {
      "put": {
        "summary": "Update a product",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "in": "body",
            "name": "product",
            "required": true,
            "schema": { "$ref": "#/definitions/ProductInput" }
          }
        ],
        "responses": {
          "200": {
            "description": "Updated",
            "schema": { "$ref": "#/definitions/Product" }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "delete": {
        "summary": "Delete a product",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": { "description": "Deleted" },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/categories": {
      "get": {
        "summary": "Get all categories",
        "responses": {
          "200": {
            "description": "Success",
            "schema": {
              "type": "array",
              "items": { "$ref": "#/definitions/Category" }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "summary": "Create new category",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "body",
            "name": "category",
            "required": true,
            "schema": { "$ref": "#/definitions/CategoryInput" }
          }
        ],
        "responses": {
          "200": {
            "description": "Created",
            "schema": { "$ref": "#/definitions/Category" }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/categories/{id}": {
      "put": {
        "summary": "Update a category",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "in": "body",
            "name": "category",
            "required": true,
            "schema": { "$ref": "#/definitions/CategoryInput" }
          }
        ],
        "responses": {
          "200": {
            "description": "Updated",
            "schema": { "$ref": "#/definitions/Category" }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "delete": {
        "summary": "Delete a category",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": { "description": "Deleted" },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/users": {
      "get": {
        "summary": "Get all users",
        "responses": {
          "200": {
            "description": "Success",
            "schema": {
              "type": "array",
              "items": { "$ref": "#/definitions/User" }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "summary": "Create new user",
        "parameters": [
          {
            "in": "body",
            "name": "user",
            "required": true,
            "schema": { "$ref": "#/definitions/UserInput" }
          }
        ],
        "responses": {
          "200": {
            "description": "Created",
            "schema": { "$ref": "#/definitions/User" }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/transactions": {
      "get": {
        "summary": "Get all transactions",
        "responses": {
          "200": {
            "description": "Success",
            "schema": {
              "type": "array",
              "items": { "$ref": "#/definitions/Transaction" }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "summary": "Create new transaction",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "body",
            "name": "transaction",
            "required": true,
            "schema": { "$ref": "#/definitions/TransactionInput" }
          }
        ],
        "responses": {
          "200": {
            "description": "Created",
            "schema": { "$ref": "#/definitions/Transaction" }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/transactions/{id}": {
      "put": {
        "summary": "Update a transaction",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "type": "string"
          },
          {
            "in": "body",
            "name": "transaction",
            "required": true,
            "schema": { "$ref": "#/definitions/TransactionInput" }
          }
        ],
        "responses": {
          "200": {
            "description": "Updated",
            "schema": { "$ref": "#/definitions/Transaction" }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "delete": {
        "summary": "Delete a transaction",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": { "description": "Deleted" },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    }
  },
  "definitions": {
    "Product": {
      "type": "object",
      "required": ["name", "sku", "price", "quantity", "description", "supplier", "category"],
      "properties": {
        "name": { "type": "string", "example": "Sample Product" },
        "sku": { "type": "string", "example": "SKU12345" },
        "price": { "type": "number", "example": 99.99 },
        "quantity": { "type": "integer", "example": 10 },
        "description": { "type": "string", "example": "A sample product description" },
        "supplier": { "type": "string", "example": "Sample Supplier" },
        "category": { "type": "string", "description": "ObjectId string referencing a Category", "example": "60d0fe4f5311236168a109ca" }
      }
    },
    "ProductInput": {
      "type": "object",
      "required": ["name", "sku", "price", "quantity"],
      "properties": {
        "name": { "type": "string", "example": "Sample Product" },
        "sku": { "type": "string", "example": "SKU12345" },
        "price": { "type": "number", "example": 99.99 },
        "quantity": { "type": "integer", "example": 10 },
        "description": { "type": "string", "example": "A sample product description" },
        "supplier": { "type": "string", "example": "Sample Supplier" },
        "category": { "type": "string", "description": "ObjectId string referencing a Category", "example": "60d0fe4f5311236168a109ca" }
      }
    },
    "Category": {
      "type": "object",
      "required": ["name", "description"],
      "properties": {
        "name": { "type": "string", "example": "Sample Category" },
        "description": { "type": "string", "example": "A sample category description" }
      }
    },
    "CategoryInput": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "example": "Sample Category" },
        "description": { "type": "string", "example": "A sample category description" }
      }
    },
    "User": {
      "type": "object",
      "required": ["googleId", "email", "name", "role"],
      "properties": {
        "googleId": { "type": "string", "example": "google-oauth2|1234567890" },
        "email": { "type": "string", "example": "user@example.com" },
        "name": { "type": "string", "example": "John Doe" },
        "role": { "type": "string", "example": "admin" }
      }
    },
    "UserInput": {
      "type": "object",
      "required": ["googleId", "email"],
      "properties": {
        "googleId": { "type": "string", "example": "google-oauth2|1234567890" },
        "email": { "type": "string", "example": "user@example.com" },
        "name": { "type": "string", "example": "John Doe" },
        "role": { "type": "string", "example": "admin" }
      }
    },
    "Transaction": {
      "type": "object",
      "required": ["type", "product", "quantity", "date", "user"],
      "properties": {
        "type": { "type": "string", "enum": ["entry", "exit"], "example": "entry" },
        "product": { "type": "string", "description": "ObjectId string referencing a Product", "example": "60d0fe4f5311236168a109ca" },
        "quantity": { "type": "integer", "example": 5 },
        "date": { "type": "string", "format": "date-time", "example": "2023-01-01T12:00:00Z" },
        "user": { "type": "string", "description": "ObjectId string referencing a User", "example": "60d0fe4f5311236168a109cb" }
      }
    },
    "TransactionInput": {
      "type": "object",
      "required": ["type", "product", "quantity"],
      "properties": {
        "type": { "type": "string", "enum": ["entry", "exit"], "example": "entry" },
        "product": { "type": "string", "description": "ObjectId string referencing a Product", "example": "60d0fe4f5311236168a109ca" },
        "quantity": { "type": "integer", "example": 5 }
      }
    }
  }
}

{
  "swagger": "2.0",
  "info": {
    "version": "1.0.0",
    "title": "Inventory API"
  },
  "basePath": "/",
  "paths": {
    "/api/products": {
      "get": {
        "summary": "Get all products",
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      },
      "post": {
        "summary": "Create new product",
        "parameters": [
          {
            "in": "body",
            "name": "product",
            "required": true,
            "schema": {
              "$ref": "#/definitions/Product"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          }
        }
      }
    }
  },
  "definitions": {
    "Product": {
      "type": "object",
      "required": ["name", "sku", "price"],
      "properties": {
        "name": { "type": "string" },
        "sku": { "type": "string" },
        "price": { "type": "number" },
        "quantity": { "type": "integer" },
        "description": { "type": "string" },
        "supplier": { "type": "string" },
        "category": { "type": "string" }
      }
    }
  }
}
